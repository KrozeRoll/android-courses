<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chat_navigation"
    app:startDestination="@id/chatFragment">

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.example.fragments.fragments.ChatFragment"
        android:label="ChatFragment"
        tools:layout="@layout/fragment_chat" >
        <action
            android:id="@+id/action_chatFragment_to_chatFragment1"
            app:destination="@id/chatFragment1" />
    </fragment>
    <fragment
        android:id="@+id/chatFragment1"
        android:name="com.example.fragments.fragments.ChatFragment1"
        android:label="ChatFragment1"
        tools:layout="@layout/fragment_chat1" >
        <argument
            android:name="count"
            app:argType="integer" />
        <action
            android:id="@+id/action_chatFragment1_to_chatFragment2"
            app:destination="@id/chatFragment2" />
    </fragment>
    <fragment
        android:id="@+id/chatFragment2"
        android:name="com.example.fragments.fragments.ChatFragment2"
        android:label="ChatFragment2"
        tools:layout="@layout/fragment_chat2">
        <argument
            android:name="count"
            app:argType="integer" />
    </fragment>
</navigation>